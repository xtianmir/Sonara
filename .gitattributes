# update.json + revocations.json are machine-written (scripts/release.mjs and
# scripts/generate-revocation-list.mjs) with LF endings; declare that canonical
# so git on Windows (autocrlf) neither converts them nor warns "LF will be
# replaced by CRLF". This file declares itself LF too, for the same reason.
/.gitattributes text eol=lf
/update.json text eol=lf
/revocations.json text eol=lf
